# Speite Configuration
# Copy this file to .env and customize as needed

# Model Configuration
# Options: tiny, base, small, medium, large
SPEITE_WHISPER_MODEL_NAME=tiny

# Device for inference (CPU only for offline compatibility)
SPEITE_DEVICE=cpu

# Language (English only for MVP)
SPEITE_LANGUAGE=en

# API Configuration
SPEITE_API_HOST=0.0.0.0
SPEITE_API_PORT=8000

# Maximum upload size in bytes (50 MB default)
SPEITE_MAX_UPLOAD_SIZE=52428800

# Audio Processing Configuration
# Target sample rate for audio preprocessing
SPEITE_SAMPLE_RATE=16000

# Tuned starting point for a typical laptop or USB microphone in a small room.
# If quiet words get cut off, lower the gate multiplier or raise attenuation.

# Trim leading and trailing silence before transcription
SPEITE_AUDIO_TRIM_SILENCE=true

# Aggressiveness for silence trimming in dB (lower = more aggressive)
SPEITE_AUDIO_TRIM_TOP_DB=24

# File transcription speech enhancement settings
SPEITE_AUDIO_PREEMPHASIS=0.97
SPEITE_AUDIO_NOISE_FLOOR_PERCENTILE=15
SPEITE_AUDIO_NOISE_GATE_MULTIPLIER=1.4
SPEITE_AUDIO_NOISE_GATE_ATTENUATION=0.25
SPEITE_AUDIO_NORMALIZATION_PEAK=0.92

# Maximum audio duration in seconds (5 minutes default)
SPEITE_MAX_AUDIO_DURATION=300

# Live transcription timing settings
SPEITE_STREAMING_MIN_AUDIO_SECONDS=0.75
SPEITE_STREAMING_SILENCE_THRESHOLD=0.01

# Separate aggressive live preprocessing profile
SPEITE_LIVE_AUDIO_TRIM_SILENCE=false
SPEITE_LIVE_AUDIO_TRIM_TOP_DB=18
SPEITE_LIVE_AUDIO_PREEMPHASIS=0.985
SPEITE_LIVE_AUDIO_NOISE_FLOOR_PERCENTILE=35
SPEITE_LIVE_AUDIO_NOISE_GATE_MULTIPLIER=2.8
SPEITE_LIVE_AUDIO_NOISE_GATE_ATTENUATION=0.05
SPEITE_LIVE_AUDIO_NORMALIZATION_PEAK=0.82

# Model Cache Directory (optional)
# If not set, defaults to ~/.cache/whisper
# SPEITE_MODEL_CACHE_DIR=/path/to/model/cache
